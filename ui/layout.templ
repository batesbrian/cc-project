package ui

templ Layout() {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<link rel="stylesheet" href="/static/css/style.css"/>
			<title>Court Counsel Templates</title>
		</head>
		<body class="min-h-screen flex flex-col bg-page">
			<main class="flex grow pt-16 pb-24 px-6 justify-center">
				{ children... }
			</main>
		</body>
	</html>
}
